/*
 * Mosaic Wallpaper Theme for QGIS
 * Deep blue night with tiled background pattern
 * "Put the bunny back in the box"
 */

/* ===== Global ===== */
QWidget {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    font-family: "Segoe UI", "SF Pro Text", sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
}

QMainWindow::separator {
    background-color: #555555;
    width: 1px;
    height: 1px;
}

QMainWindow::separator:hover {
    background-color: #e94560;
}

/* ===== Menu Bar ===== */
QMenuBar {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    border-bottom: 1px solid #0f3460;
}

QMenuBar::item {
    background: transparent;
    padding: 4px 8px;
}

QMenuBar::item:selected {
    background-color: #e94560;
    color: #ffffff;
}

QMenu {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    border: 1px solid #0f3460;
    padding: 4px 0;
}

QMenu::item {
    padding: 5px 28px 5px 24px;
}

QMenu::item:selected {
    background-color: #e94560;
    color: #ffffff;
}

QMenu::separator {
    height: 1px;
    background-color: #0f3460;
    margin: 4px 8px;
}

/* ===== Toolbar ===== */
QToolBar {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    border-bottom: 1px solid #0f3460;
    spacing: 2px;
    padding: 2px;
}

QToolButton {
    background: transparent;
    color: #e0e0e0;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 4px 6px;
}

QToolButton:hover {
    background-color: #0f3460;
    border-color: #e94560;
}

QToolButton:pressed {
    background-color: #e94560;
}

QToolButton:checked {
    background-color: #e94560;
    color: #ffffff;
}

/* ===== Tabs ===== */
QTabWidget::pane {
    border: 1px solid #0f3460;
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
}

QTabBar::tab {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #8899aa;
    border: 1px solid #0f3460;
    border-bottom: none;
    padding: 6px 16px;
}

QTabBar::tab:selected {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e94560;
    border-bottom: 2px solid #e94560;
}

QTabBar::tab:hover:!selected {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
}

/* ===== Buttons ===== */
QPushButton {
    background-color: #e94560;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 16px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #ff6b81;
}

QPushButton:pressed {
    background-color: #c0392b;
}

QPushButton:disabled {
    background-color: #2c2c54;
    color: #555577;
}

/* ===== Lists / Trees ===== */
QListView, QTreeView, QTableView {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    alternate-background-color: rgba(22, 33, 62, 0.5);
    color: #e0e0e0;
    border: 1px solid #0f3460;
    outline: none;
}

QListView::item, QTreeView::item {
    padding: 4px 8px;
}

QListView::item:selected, QTreeView::item:selected {
    background-color: #e94560;
    color: #ffffff;
}

QListView::item:hover, QTreeView::item:hover {
    background-color: #0f3460;
}

QHeaderView::section {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    border: 1px solid #0f3460;
    padding: 4px 8px;
    font-weight: bold;
}

/* ===== Scrollbar ===== */
QScrollBar:vertical {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    width: 14px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: #e94560;
    border-radius: 7px;
    min-height: 30px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background-color: #ff6b81;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    height: 14px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: #e94560;
    border-radius: 7px;
    min-width: 30px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #ff6b81;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    background: none;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* ===== Line Edit / Spin Box ===== */
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    border: 1px solid #0f3460;
    border-radius: 4px;
    padding: 4px 8px;
}

QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border-color: #e94560;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #0f3460;
    background-color: rgba(22, 33, 62, 0.7);
}

QComboBox::down-arrow {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #e94560;
}

QComboBox QAbstractItemView {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    selection-background-color: #e94560;
    border: 1px solid #0f3460;
}

/* ===== Check / Radio - CAGE FACE ICONS ===== */
QCheckBox::indicator, QRadioButton::indicator {
    width: 22px;
    height: 22px;
    border: 2px solid #0f3460;
    border-radius: 4px;
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    image: url(icons/cage_16.png);
}

QRadioButton::indicator {
    border-radius: 11px;
}

QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    border-color: #e94560;
    background-color: #e94560;
    image: url(icons/cage_16.png);
}

QCheckBox::indicator:hover, QRadioButton::indicator:hover {
    border-color: #e94560;
}

/* ===== Group Box ===== */
QGroupBox {
    color: #e94560;
    border: 1px solid #0f3460;
    border-radius: 6px;
    margin-top: 10px;
    padding-top: 14px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 6px;
}

/* ===== Status Bar ===== */
QStatusBar {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #ffffff;
    border-top: 1px solid #e94560;
}

/* ===== Label ===== */
QLabel {
    color: #e0e0e0;
    background: transparent;
}

/* ===== Dialog ===== */
QDialog {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
}

/* ===== Tooltip ===== */
QToolTip {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #ffffff;
    border: 1px solid #e94560;
    padding: 4px 8px;
    border-radius: 4px;
}

/* ===== Progress Bar ===== */
QProgressBar {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    text-align: center;
    height: 16px;
}

QProgressBar::chunk {
    background-color: #e94560;
    border-radius: 4px;
}

/* ===== Splitter ===== */
QSplitter::handle {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
}

QSplitter::handle:hover {
    background-color: #e94560;
}

QSplitter::handle:horizontal { width: 2px; }
QSplitter::handle:vertical { height: 2px; }

/* ===== Dock Widget ===== */
QDockWidget {
    color: #e0e0e0;
}

QDockWidget::title {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    text-align: left;
    padding: 6px 8px;
    border-bottom: 1px solid #0f3460;
}

/* ===== Text Browser / Edit ===== */
QTextBrowser, QTextEdit {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    border: 1px solid #0f3460;
}

/* ===== Message Bar (QGIS) ===== */
QgsMessageBar {
    background-image: url(icons/cage_bg.jpg);
    background-repeat: repeat;
    color: #e0e0e0;
    border: 1px solid #e94560;
}
